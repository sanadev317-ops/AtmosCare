# Shared workspace-wide database settings
# MongoDB Atlas example:
# DATABASE_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DATABASE_URI=mongodb://localhost:27017
DATABASE_NAME=AtmosCareDB

# Optional legacy aliases supported during transition
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=AtmosCareDB
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=AtmosCareDB

# Email configuration
SMTP_FROM=you@example.com
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your_app_password

# External API keys (set in Railway/hosting dashboard — never commit real values)
WAQI_API_KEY=your_waqi_api_key
ACCUWEATHER_API_KEY=your_accuweather_api_key
GOOGLE_API_KEY=your_google_maps_key
