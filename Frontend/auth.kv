<SignUpScreen>:
    name: "signup"

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.97, 0.98, 1, 1

        # ── Compact navy header ──
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "160dp"
            padding: "20dp", "24dp", "20dp", "16dp"
            spacing: "8dp"
            md_bg_color: 0.08, 0.12, 0.22, 1

            MDBoxLayout:
                orientation: "horizontal"
                spacing: "12dp"
                size_hint_y: None
                height: "48dp"

                MDIcon:
                    icon: "weather-hazy"
                    font_size: "36sp"
                    theme_text_color: "Custom"
                    text_color: 0, 0.82, 0.76, 1
                    size_hint_x: None
                    width: "44dp"
                    halign: "center"
                    pos_hint: {"center_y": 0.5}

                MDLabel:
                    text: "AtmosCare"
                    font_style: "H5"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    halign: "left"
                    valign: "center"
                    pos_hint: {"center_y": 0.5}

            # accent pill
            MDBoxLayout:
                size_hint: None, None
                size: "44dp", "3dp"
                md_bg_color: 0, 0.82, 0.76, 1
                radius: [2]

            MDLabel:
                text: "Join the clean-air movement"
                font_size: "12sp"
                theme_text_color: "Custom"
                text_color: 0.72, 0.80, 0.92, 1
                halign: "left"
                valign: "center"
                size_hint_y: None
                height: "22dp"

        # ── Form area ──
        ScrollView:
            do_scroll_x: False

            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp", "16dp", "16dp", "20dp"
                spacing: "14dp"
                size_hint_y: None
                height: self.minimum_height

                MDCard:
                    orientation: "vertical"
                    spacing: "14dp"
                    padding: "20dp"
                    radius: [20]
                    size_hint_y: None
                    height: "560dp"
                    md_bg_color: 1, 1, 1, 1
                    elevation: 3

                    # Title row with icon tile
                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "56dp"
                        spacing: "12dp"

                        MDCard:
                            size_hint: None, None
                            size: "48dp", "48dp"
                            radius: [12]
                            md_bg_color: 0.93, 1, 0.98, 1
                            elevation: 0
                            pos_hint: {"center_y": 0.5}

                            MDIcon:
                                icon: "shield-account-outline"
                                theme_text_color: "Custom"
                                text_color: 0, 0.69, 0.64, 1
                                font_size: "26sp"
                                halign: "center"
                                valign: "center"
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: "2dp"
                            pos_hint: {"center_y": 0.5}

                            MDLabel:
                                text: "Create Account"
                                font_style: "H6"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.08, 0.12, 0.22, 1
                                halign: "left"
                                valign: "center"
                                size_hint_y: None
                                height: "26dp"

                            MDLabel:
                                text: "Start monitoring your air quality"
                                font_size: "11sp"
                                theme_text_color: "Custom"
                                text_color: 0.42, 0.45, 0.52, 1
                                halign: "left"
                                valign: "center"
                                size_hint_y: None
                                height: "18dp"

                    MDTextField:
                        id: username
                        hint_text: "Username"
                        icon_left: "account-outline"
                        mode: "rectangle"
                        line_color_focus: 0, 0.69, 0.64, 1
                        hint_text_color_focus: 0, 0.69, 0.64, 1
                        text_color_normal: 0.1, 0.12, 0.18, 1
                        text_color_focus: 0.1, 0.12, 0.18, 1
                        radius: [12, 12, 12, 12]

                    MDTextField:
                        id: email
                        hint_text: "Email"
                        icon_left: "email-outline"
                        mode: "rectangle"
                        line_color_focus: 0, 0.69, 0.64, 1
                        hint_text_color_focus: 0, 0.69, 0.64, 1
                        text_color_normal: 0.1, 0.12, 0.18, 1
                        text_color_focus: 0.1, 0.12, 0.18, 1
                        radius: [12, 12, 12, 12]

                    MDTextField:
                        id: password
                        hint_text: "Password"
                        password: True
                        icon_left: "lock-outline"
                        mode: "rectangle"
                        line_color_focus: 0, 0.69, 0.64, 1
                        hint_text_color_focus: 0, 0.69, 0.64, 1
                        text_color_normal: 0.1, 0.12, 0.18, 1
                        text_color_focus: 0.1, 0.12, 0.18, 1
                        radius: [12, 12, 12, 12]

                    MDRaisedButton:
                        text: "Create Account"
                        md_bg_color: 0, 0.69, 0.64, 1
                        text_color: 1, 1, 1, 1
                        font_size: "15sp"
                        size_hint_x: 1
                        size_hint_y: None
                        height: "50dp"
                        elevation: 3
                        pos_hint: {"center_x": 0.5}
                        on_release: root.signup_user()

                MDFlatButton:
                    text: "Already have an account? Log in"
                    theme_text_color: "Custom"
                    text_color: 0.22, 0.42, 0.85, 1
                    pos_hint: {"center_x": 0.5}
                    size_hint_y: None
                    height: "44dp"
                    on_release: root.manager.current = "login"


<LoginScreen>:
    name: "login"

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.97, 0.98, 1, 1

        # ── Compact navy header ──
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: "170dp"
            padding: "20dp", "28dp", "20dp", "18dp"
            spacing: "8dp"
            md_bg_color: 0.08, 0.12, 0.22, 1

            MDBoxLayout:
                orientation: "horizontal"
                spacing: "12dp"
                size_hint_y: None
                height: "52dp"

                MDIcon:
                    icon: "weather-hazy"
                    font_size: "40sp"
                    theme_text_color: "Custom"
                    text_color: 0, 0.82, 0.76, 1
                    size_hint_x: None
                    width: "48dp"
                    halign: "center"
                    pos_hint: {"center_y": 0.5}

                MDLabel:
                    text: "AtmosCare"
                    font_style: "H4"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    halign: "left"
                    valign: "center"
                    pos_hint: {"center_y": 0.5}

            # accent pill
            MDBoxLayout:
                size_hint: None, None
                size: "44dp", "3dp"
                md_bg_color: 0, 0.82, 0.76, 1
                radius: [2]

            MDLabel:
                text: "Welcome back — let's check your air today"
                font_size: "12sp"
                theme_text_color: "Custom"
                text_color: 0.72, 0.80, 0.92, 1
                halign: "left"
                valign: "center"
                size_hint_y: None
                height: "22dp"

        # ── Form area ──
        ScrollView:
            do_scroll_x: False

            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp", "16dp", "16dp", "20dp"
                spacing: "14dp"
                size_hint_y: None
                height: self.minimum_height

                MDCard:
                    orientation: "vertical"
                    spacing: "16dp"
                    padding: "20dp"
                    radius: [20]
                    size_hint_y: None
                    height: "400dp"
                    md_bg_color: 1, 1, 1, 1
                    elevation: 3

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "56dp"
                        spacing: "12dp"

                        MDCard:
                            size_hint: None, None
                            size: "48dp", "48dp"
                            radius: [12]
                            md_bg_color: 0.93, 1, 0.98, 1
                            elevation: 0
                            pos_hint: {"center_y": 0.5}

                            MDIcon:
                                icon: "login-variant"
                                theme_text_color: "Custom"
                                text_color: 0, 0.69, 0.64, 1
                                font_size: "26sp"
                                halign: "center"
                                valign: "center"
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: "2dp"
                            pos_hint: {"center_y": 0.5}

                            MDLabel:
                                text: "Sign In"
                                font_style: "H6"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.08, 0.12, 0.22, 1
                                halign: "left"
                                valign: "center"
                                size_hint_y: None
                                height: "26dp"

                            MDLabel:
                                text: "Enter your credentials to continue"
                                font_size: "11sp"
                                theme_text_color: "Custom"
                                text_color: 0.42, 0.45, 0.52, 1
                                halign: "left"
                                valign: "center"
                                size_hint_y: None
                                height: "18dp"

                    MDTextField:
                        id: email
                        hint_text: "Email"
                        icon_left: "email-outline"
                        mode: "rectangle"
                        multiline: False
                        write_tab: False
                        on_text_validate: root.ids.password.focus = True
                        line_color_focus: 0, 0.69, 0.64, 1
                        hint_text_color_focus: 0, 0.69, 0.64, 1
                        text_color_normal: 0.1, 0.12, 0.18, 1
                        text_color_focus: 0.1, 0.12, 0.18, 1
                        radius: [12, 12, 12, 12]

                    MDTextField:
                        id: password
                        hint_text: "Password"
                        password: True
                        icon_left: "lock-outline"
                        mode: "rectangle"
                        multiline: False
                        write_tab: False
                        on_text_validate: root.login_user()
                        line_color_focus: 0, 0.69, 0.64, 1
                        hint_text_color_focus: 0, 0.69, 0.64, 1
                        text_color_normal: 0.1, 0.12, 0.18, 1
                        text_color_focus: 0.1, 0.12, 0.18, 1
                        radius: [12, 12, 12, 12]

                    MDRaisedButton:
                        text: "Login"
                        md_bg_color: 0, 0.69, 0.64, 1
                        text_color: 1, 1, 1, 1
                        font_size: "15sp"
                        size_hint_x: 1
                        size_hint_y: None
                        height: "50dp"
                        elevation: 3
                        pos_hint: {"center_x": 0.5}
                        on_release: root.login_user()

                MDFlatButton:
                    text: "Don't have an account? Sign Up"
                    theme_text_color: "Custom"
                    text_color: 0.22, 0.42, 0.85, 1
                    pos_hint: {"center_x": 0.5}
                    size_hint_y: None
                    height: "44dp"
                    on_release: root.manager.current = "signup"
