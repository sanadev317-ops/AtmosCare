<SettingsScreen>:

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.97, 0.98, 1, 1

        MDTopAppBar:
            title: "Settings"
            elevation: 4
            left_action_items: [["arrow-left", lambda x: app.go_to_dashboard()]]
            md_bg_color: 0.08, 0.12, 0.22, 1
            specific_text_color: 1, 1, 1, 1

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp"
                spacing: "16dp"
                size_hint_y: None
                height: self.minimum_height

                # ══════════════════════════════════════════════
                # PERSONAL INFO CARD
                # ══════════════════════════════════════════════
                MDCard:
                    orientation: "vertical"
                    padding: "18dp"
                    spacing: "14dp"
                    radius: [22]
                    size_hint_y: None
                    height: "220dp"
                    md_bg_color: 1, 1, 1, 1
                    elevation: 3

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "36dp"
                        spacing: "10dp"

                        MDCard:
                            size_hint: None, None
                            size: "36dp", "36dp"
                            radius: [10]
                            md_bg_color: 0.90, 0.99, 0.97, 1
                            elevation: 0

                            MDIcon:
                                icon: "account-edit-outline"
                                theme_text_color: "Custom"
                                text_color: 0, 0.69, 0.64, 1
                                font_size: "22sp"
                                halign: "center"
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}

                        MDBoxLayout:
                            orientation: "vertical"

                            MDLabel:
                                text: "Personal Info"
                                font_style: "Subtitle1"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.08, 0.12, 0.22, 1

                            MDLabel:
                                text: "Your name and default location"
                                font_size: "10sp"
                                theme_text_color: "Custom"
                                text_color: 0.55, 0.6, 0.7, 1

                    MDTextField:
                        id: name_input
                        hint_text: "Enter your name"
                        icon_left: "account-outline"
                        mode: "rectangle"
                        text: app.settings_data.get("name", "User")
                        line_color_focus: 0, 0.69, 0.64, 1
                        hint_text_color_focus: 0, 0.69, 0.64, 1
                        text_color_normal: 0.1, 0.12, 0.18, 1
                        text_color_focus: 0.1, 0.12, 0.18, 1
                        radius: [14, 14, 14, 14]

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing: "10dp"
                        MDTextField:
                            id: location_input
                            hint_text: "Enter your location"
                            icon_left: "map-marker-outline"
                            mode: "rectangle"
                            text: app.settings_data.get("location", "Unknown Location")
                            line_color_focus: 0, 0.69, 0.64, 1
                            hint_text_color_focus: 0, 0.69, 0.64, 1
                            text_color_normal: 0.1, 0.12, 0.18, 1
                            text_color_focus: 0.1, 0.12, 0.18, 1
                            radius: [14, 14, 14, 14]
                            size_hint_x: 0.72

                        MDRaisedButton:
                            text: "Detect"
                            size_hint_x: 0.28
                            md_bg_color: 0.22, 0.42, 0.85, 1
                            text_color: 1, 1, 1, 1
                            elevation: 3
                            on_release: app.get_current_location()

                # ══════════════════════════════════════════════
                # ALERT PREFERENCES CARD
                # ══════════════════════════════════════════════
                MDCard:
                    orientation: "vertical"
                    padding: "18dp"
                    spacing: "12dp"
                    radius: [22]
                    size_hint_y: None
                    height: "350dp"
                    md_bg_color: 1, 1, 1, 1
                    elevation: 3

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "36dp"
                        spacing: "10dp"

                        MDCard:
                            size_hint: None, None
                            size: "36dp", "36dp"
                            radius: [10]
                            md_bg_color: 1, 0.94, 0.86, 1
                            elevation: 0

                            MDIcon:
                                icon: "bell-ring-outline"
                                theme_text_color: "Custom"
                                text_color: 0.92, 0.55, 0.1, 1
                                font_size: "22sp"
                                halign: "center"
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}

                        MDBoxLayout:
                            orientation: "vertical"

                            MDLabel:
                                text: "Alert Preferences"
                                font_style: "Subtitle1"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.08, 0.12, 0.22, 1

                            MDLabel:
                                text: "Notifications when smog or weather worsens"
                                font_size: "10sp"
                                theme_text_color: "Custom"
                                text_color: 0.55, 0.6, 0.7, 1

                    # ── Smog row ──
                    MDCard:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "44dp"
                        radius: [12]
                        md_bg_color: 1, 0.95, 0.93, 1
                        elevation: 0
                        padding: "8dp", "2dp"
                        spacing: "8dp"

                        MDCheckbox:
                            id: smog_checkbox
                            active: app.settings_data.get("smog", True)
                            size_hint: None, None
                            size: "36dp", "36dp"
                            pos_hint: {"center_y": 0.5}
                            selected_color: 0, 0.69, 0.64, 1
                            unselected_color: 0.42, 0.45, 0.52, 1

                        MDIcon:
                            icon: "weather-fog"
                            theme_text_color: "Custom"
                            text_color: 0.9, 0.35, 0.25, 1
                            size_hint_x: None
                            width: "24dp"
                            pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: "Smog Level Alerts"
                            font_size: "13sp"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 0.08, 0.12, 0.22, 1

                    # ── Rain row ──
                    MDCard:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "44dp"
                        radius: [12]
                        md_bg_color: 0.94, 0.98, 1, 1
                        elevation: 0
                        padding: "8dp", "2dp"
                        spacing: "8dp"

                        MDCheckbox:
                            id: rain_checkbox
                            active: app.settings_data.get("rain", False)
                            size_hint: None, None
                            size: "36dp", "36dp"
                            pos_hint: {"center_y": 0.5}
                            selected_color: 0, 0.69, 0.64, 1
                            unselected_color: 0.42, 0.45, 0.52, 1

                        MDIcon:
                            icon: "weather-rainy"
                            theme_text_color: "Custom"
                            text_color: 0.22, 0.55, 0.85, 1
                            size_hint_x: None
                            width: "24dp"
                            pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: "Rain Alerts"
                            font_size: "13sp"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 0.08, 0.12, 0.22, 1

                    # ── Snow row ──
                    MDCard:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "44dp"
                        radius: [12]
                        md_bg_color: 0.94, 0.97, 1, 1
                        elevation: 0
                        padding: "8dp", "2dp"
                        spacing: "8dp"

                        MDCheckbox:
                            id: snow_checkbox
                            active: app.settings_data.get("snow", False)
                            size_hint: None, None
                            size: "36dp", "36dp"
                            pos_hint: {"center_y": 0.5}
                            selected_color: 0, 0.69, 0.64, 1
                            unselected_color: 0.42, 0.45, 0.52, 1

                        MDIcon:
                            icon: "weather-snowy"
                            theme_text_color: "Custom"
                            text_color: 0.65, 0.78, 0.92, 1
                            size_hint_x: None
                            width: "24dp"
                            pos_hint: {"center_y": 0.5}

                        MDLabel:
                            text: "Snow Alerts"
                            font_size: "13sp"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 0.08, 0.12, 0.22, 1

                # Save Button
                MDRaisedButton:
                    text: "Save Changes"
                    pos_hint: {"center_x": 0.5}
                    size_hint_x: 1
                    size_hint_y: None
                    height: "52dp"
                    md_bg_color: 0, 0.69, 0.64, 1
                    text_color: 1, 1, 1, 1
                    elevation: 4
                    on_release:
                        app.save_settings(name_input.text, location_input.text, rain_checkbox.active, snow_checkbox.active, smog_checkbox.active)

                Widget:
                    size_hint_y: None
                    height: "20dp"

        # ══════════════════════════════════════════════
        # BOTTOM NAVIGATION BAR
        # ══════════════════════════════════════════════
        MDCard:
            size_hint_y: None
            height: "68dp"
            md_bg_color: 0.08, 0.12, 0.22, 1
            radius: [0]
            elevation: 8

            MDBoxLayout:
                orientation: "horizontal"
                padding: "4dp", "0dp"

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    Widget:
                        size_hint_y: None
                        height: "3dp"
                    MDIconButton:
                        icon: "view-dashboard-outline"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                        on_release: app.go_to_dashboard()
                    MDLabel:
                        text: "Dashboard"
                        halign: "center"
                        font_size: "10sp"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    Widget:
                        size_hint_y: None
                        height: "3dp"
                    MDIconButton:
                        icon: "chart-line"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                        on_release: app.open_analytics()
                    MDLabel:
                        text: "Analytics"
                        halign: "center"
                        font_size: "10sp"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    Widget:
                        size_hint_y: None
                        height: "3dp"
                    MDIconButton:
                        icon: "map-marker-outline"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                        on_release: setattr(app.root, 'current', 'locations')
                    MDLabel:
                        text: "Locations"
                        halign: "center"
                        font_size: "10sp"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    MDBoxLayout:
                        size_hint_y: None
                        height: "3dp"
                        md_bg_color: 0, 0.82, 0.76, 1
                        radius: [0, 0, 2, 2]
                    MDIconButton:
                        icon: "cog"
                        theme_text_color: "Custom"
                        text_color: 0, 0.82, 0.76, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                    MDLabel:
                        text: "Settings"
                        halign: "center"
                        font_size: "10sp"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 0, 0.82, 0.76, 1
