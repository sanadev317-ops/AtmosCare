<ProfileScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.97, 0.98, 1, 1

        MDTopAppBar:
            title: "My Profile"
            elevation: 4
            md_bg_color: 0.08, 0.12, 0.22, 1
            specific_text_color: 1, 1, 1, 1
            left_action_items: [["arrow-left", lambda x: root.go_back_to_dashboard()]]

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: "16dp"
                spacing: "16dp"
                size_hint_y: None
                height: self.minimum_height

                # ══════════════════════════════════════════════
                # PROFILE HEADER CARD
                # ══════════════════════════════════════════════
                MDCard:
                    orientation: "vertical"
                    padding: "20dp"
                    spacing: "10dp"
                    radius: [20]
                    size_hint_y: None
                    height: "280dp"
                    md_bg_color: 1, 1, 1, 1
                    elevation: 3

                    # Avatar area
                    AnchorLayout:
                        anchor_x: "center"
                        size_hint_y: None
                        height: "120dp"

                        MDCard:
                            size_hint: None, None
                            size: "110dp", "110dp"
                            radius: [55]
                            md_bg_color: 0.93, 1, 0.98, 1
                            elevation: 0

                            AnchorLayout:
                                anchor_x: "center"
                                anchor_y: "center"

                                MDIcon:
                                    icon: "account-circle"
                                    font_size: "86sp"
                                    theme_text_color: "Custom"
                                    text_color: 0, 0.69, 0.64, 1

                    MDLabel:
                        id: profile_name
                        text: "User Name"
                        font_style: "H5"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 0.08, 0.12, 0.22, 1
                        halign: "center"
                        size_hint_y: None
                        height: "30dp"

                    MDLabel:
                        id: profile_email
                        text: "user@example.com"
                        font_size: "13sp"
                        theme_text_color: "Custom"
                        text_color: 0.42, 0.45, 0.52, 1
                        halign: "center"
                        size_hint_y: None
                        height: "20dp"

                    # Role badge pill
                    AnchorLayout:
                        anchor_x: "center"
                        size_hint_y: None
                        height: "30dp"

                        MDCard:
                            size_hint: None, None
                            size: "130dp", "26dp"
                            radius: [13]
                            md_bg_color: 0.93, 1, 0.98, 1
                            elevation: 0

                            MDLabel:
                                id: profile_role
                                text: "👤  User"
                                font_size: "11sp"
                                bold: True
                                halign: "center"
                                theme_text_color: "Custom"
                                text_color: 0, 0.69, 0.64, 1

                # ══════════════════════════════════════════════
                # LOCATION CARD (with accent strip)
                # ══════════════════════════════════════════════
                MDCard:
                    orientation: "horizontal"
                    radius: [20]
                    size_hint_y: None
                    height: "90dp"
                    md_bg_color: 1, 1, 1, 1
                    elevation: 2
                    padding: 0, 0

                    MDBoxLayout:
                        size_hint_x: None
                        width: "6dp"
                        md_bg_color: 0, 0.69, 0.64, 1
                        radius: [20, 0, 0, 20]

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "14dp"
                        spacing: "4dp"

                        MDBoxLayout:
                            orientation: "horizontal"
                            spacing: "8dp"
                            size_hint_y: None
                            height: "24dp"

                            MDIcon:
                                icon: "map-marker"
                                theme_text_color: "Custom"
                                text_color: 0, 0.69, 0.64, 1
                                size_hint_x: None
                                width: "24dp"

                            MDLabel:
                                text: "Location"
                                font_size: "13sp"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.08, 0.12, 0.22, 1

                        MDLabel:
                            id: profile_location
                            text: "Not Set"
                            font_size: "13sp"
                            theme_text_color: "Custom"
                            text_color: 0.42, 0.45, 0.52, 1

                # ══════════════════════════════════════════════
                # WEATHER ALERTS CARD (stat tiles)
                # ══════════════════════════════════════════════
                MDCard:
                    orientation: "vertical"
                    padding: "16dp"
                    spacing: "12dp"
                    radius: [20]
                    size_hint_y: None
                    height: "200dp"
                    md_bg_color: 1, 1, 1, 1
                    elevation: 2

                    MDBoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: "32dp"
                        spacing: "8dp"

                        MDCard:
                            size_hint: None, None
                            size: "32dp", "32dp"
                            radius: [9]
                            md_bg_color: 1, 0.94, 0.86, 1
                            elevation: 0

                            MDIcon:
                                icon: "bell-ring-outline"
                                theme_text_color: "Custom"
                                text_color: 0.92, 0.55, 0.1, 1
                                font_size: "20sp"
                                halign: "center"
                                pos_hint: {"center_x": 0.5, "center_y": 0.5}

                        MDLabel:
                            text: "Weather Alerts"
                            font_style: "Subtitle1"
                            bold: True
                            theme_text_color: "Custom"
                            text_color: 0.08, 0.12, 0.22, 1

                    # Stat tiles grid
                    MDGridLayout:
                        cols: 2
                        spacing: "10dp"
                        size_hint_y: None
                        height: "110dp"

                        # Rain
                        MDCard:
                            orientation: "vertical"
                            radius: [14]
                            md_bg_color: 0.94, 0.98, 1, 1
                            elevation: 0
                            padding: "10dp"
                            spacing: "4dp"

                            MDIcon:
                                icon: "weather-rainy"
                                theme_text_color: "Custom"
                                text_color: 0.22, 0.55, 0.85, 1
                                font_size: "24sp"
                                halign: "center"
                                size_hint_y: None
                                height: "28dp"

                            MDLabel:
                                text: "Rain"
                                font_size: "10sp"
                                halign: "center"
                                theme_text_color: "Custom"
                                text_color: 0.42, 0.45, 0.52, 1
                                size_hint_y: None
                                height: "14dp"

                            MDLabel:
                                id: profile_rain
                                text: "No"
                                font_size: "14sp"
                                bold: True
                                halign: "center"
                                theme_text_color: "Custom"
                                text_color: 0.08, 0.12, 0.22, 1

                        # Snow
                        MDCard:
                            orientation: "vertical"
                            radius: [14]
                            md_bg_color: 0.94, 0.97, 1, 1
                            elevation: 0
                            padding: "10dp"
                            spacing: "4dp"

                            MDIcon:
                                icon: "weather-snowy"
                                theme_text_color: "Custom"
                                text_color: 0.65, 0.78, 0.92, 1
                                font_size: "24sp"
                                halign: "center"
                                size_hint_y: None
                                height: "28dp"

                            MDLabel:
                                text: "Snow"
                                font_size: "10sp"
                                halign: "center"
                                theme_text_color: "Custom"
                                text_color: 0.42, 0.45, 0.52, 1
                                size_hint_y: None
                                height: "14dp"

                            MDLabel:
                                id: profile_snow
                                text: "No"
                                font_size: "14sp"
                                bold: True
                                halign: "center"
                                theme_text_color: "Custom"
                                text_color: 0.08, 0.12, 0.22, 1

                # EDIT PROFILE BUTTON
                MDRaisedButton:
                    text: "Edit Profile"
                    size_hint_y: None
                    height: "52dp"
                    size_hint_x: 1
                    md_bg_color: 0, 0.69, 0.64, 1
                    text_color: 1, 1, 1, 1
                    elevation: 4
                    on_press: app.open_settings()

                # LOGOUT BUTTON
                MDRaisedButton:
                    text: "Logout"
                    size_hint_y: None
                    height: "52dp"
                    size_hint_x: 1
                    md_bg_color: 0.9, 0.22, 0.22, 1
                    text_color: 1, 1, 1, 1
                    elevation: 4
                    on_press: app.logout()

                Widget:
                    size_hint_y: None
                    height: "10dp"

        # ══════════════════════════════════════════════
        # BOTTOM NAVIGATION BAR
        # ══════════════════════════════════════════════
        MDCard:
            size_hint_y: None
            height: "68dp"
            md_bg_color: 0.08, 0.12, 0.22, 1
            radius: [0]
            elevation: 8

            MDBoxLayout:
                orientation: "horizontal"
                padding: "4dp", "0dp"

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    Widget:
                        size_hint_y: None
                        height: "3dp"
                    MDIconButton:
                        icon: "view-dashboard-outline"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                        on_release: app.go_to_dashboard()
                    MDLabel:
                        text: "Dashboard"
                        halign: "center"
                        font_size: "10sp"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    Widget:
                        size_hint_y: None
                        height: "3dp"
                    MDIconButton:
                        icon: "chart-line"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                        on_release: app.open_analytics()
                    MDLabel:
                        text: "Analytics"
                        halign: "center"
                        font_size: "10sp"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    Widget:
                        size_hint_y: None
                        height: "3dp"
                    MDIconButton:
                        icon: "map-marker-outline"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                        on_release: setattr(app.root, 'current', 'locations')
                    MDLabel:
                        text: "Locations"
                        halign: "center"
                        font_size: "10sp"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1

                MDBoxLayout:
                    orientation: "vertical"
                    spacing: "0dp"
                    Widget:
                        size_hint_y: None
                        height: "3dp"
                    MDIconButton:
                        icon: "cog-outline"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
                        icon_size: "22sp"
                        pos_hint: {"center_x": 0.5}
                        on_release: app.open_settings()
                    MDLabel:
                        text: "Settings"
                        halign: "center"
                        font_size: "10sp"
                        theme_text_color: "Custom"
                        text_color: 0.55, 0.6, 0.7, 1
